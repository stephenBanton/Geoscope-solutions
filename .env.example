# =============================================================================
# GeoScope Environment Configuration — copy this file to .env and fill in values
# =============================================================================

# --- PostgreSQL (PostGIS) Primary Data Source ---
# Use PostgreSQL for all persistent data (orders, datasets, reports)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=geoscope
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# Dedicated database for large environmental datasets
DATA_PG_HOST=localhost
DATA_PG_PORT=5432
DATA_PG_DATABASE=geoscope
DATA_PG_USER=postgres
DATA_PG_PASSWORD=your-postgres-password

# --- Authentication ---
JWT_SECRET=replace-with-long-random-secret-min-32-chars
AUTH_SECURITY_MODE=jwt  # Options: 'jwt' or 'off'
STAFF_EMAIL_DOMAINS=geoscopesolutions.com,geoscope.com

# --- Server Config ---
PORT=5000
NODE_ENV=development  # 'development' or 'production'
VERCEL=1  # Set to 1 on Vercel serverless platform

# --- Email Configuration (Required for order & contact notifications) ---
# Gmail: Use with app password (not regular password)
# Other providers: Configure SMTP_HOST and SMTP_PORT instead
GMAIL_USER=info@geoscopesolutions.com
GMAIL_PASS=your-gmail-app-password
ADMIN_NOTIFICATION_EMAIL=info@geoscopesolutions.com
ORDER_EMAIL_ADDRESS=info@geoscopesolutions.com

# Alternative SMTP Configuration (e.g., Namecheap Private Email)
# SMTP_HOST=mail.privateemail.com
# SMTP_PORT=587
# SMTP_USER=info@geoscopesolutions.com
# SMTP_PASS=your-email-password

# --- Test Client Configuration ---
# These clients are whitelisted (not charged for orders)
# Configured in server.js testClientWhitelist array
TEST_CLIENT_EMAILS=nyangelos4@gmail.com,test@geoscope.com

# --- OpenAI (optional for report generation) ---
OPENAI_API_KEY=sk-your-api-key

# --- Supabase (optional for file storage & lightweight data) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# --- MongoDB (optional legacy fallback) ---
# MONGODB_URI=mongodb://127.0.0.1:27017/geoscope

# --- Google Maps (optional for geocoding) ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- PayPal (optional for payments) ---
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# Vercel: Set environment variables in Project Settings > Environment Variables
# Local Dev: Copy to .env and fill in your local values
# Production: Use only secure, app-specific passwords (not account passwords)

