# =============================================================================
# GeoScope Environment Configuration — copy this file to .env and fill in values
# =============================================================================

# --- PostgreSQL (PostGIS) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=geoscope
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# --- Auth ---
JWT_SECRET=replace-with-long-random-secret
AUTH_SECURITY_MODE=jwt
STAFF_EMAIL_DOMAINS=geoscope.com

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Mailer (optional) ---
GMAIL_USER=your-mailbox@gmail.com
GMAIL_PASS=your-app-password
ADMIN_NOTIFICATION_EMAIL=ops@geoscope.com

# --- OpenAI (optional) ---
OPENAI_API_KEY=sk-your-api-key

# --- Supabase (optional) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# --- MongoDB (optional legacy fallback) ---
# MONGODB_URI=mongodb://127.0.0.1:27017/geoscope

# --- Google Maps (optional) ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
